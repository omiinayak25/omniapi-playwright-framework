# =============================================================================
# .env.example — Template for environment configuration
# -----------------------------------------------------------------------------
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env (which is git-ignored — secrets never commit).
#
# WHY:
#   The 12-Factor App principle: config lives in the ENVIRONMENT, not in code.
#   The SAME built artifact runs against dev/staging/prod by swapping .env only.
# =============================================================================

# Which environment profile to load (dev | staging | prod). Drives defaults.
TEST_ENV=dev

# Primary API under test (used as Playwright's baseURL default).
BASE_URL=https://restful-booker.herokuapp.com

# Per-API base URLs used in later phases (kept here for one source of truth).
DUMMYJSON_URL=https://dummyjson.com
REQRES_URL=https://reqres.in
JSONPLACEHOLDER_URL=https://jsonplaceholder.typicode.com
# httpbingo.org = reliable httpbin reimplementation (httpbin.org is often down).
HTTPBIN_URL=https://httpbingo.org
POSTMAN_ECHO_URL=https://postman-echo.com
OPEN_BREWERY_URL=https://api.openbrewerydb.org
COUNTRIES_GQL_URL=https://countries.trevorblades.com
GRAPHQL_ZERO_URL=https://graphqlzero.almansi.me

# ReqRes (custom API example). /api/* endpoints require a registered key —
# create a free one at https://app.reqres.in/api-keys, then set it here to
# enable the key-gated happy-path test in tests/crud/reqres-collections.spec.ts.
REQRES_API_KEY=

# Default credentials for auth phases (demo APIs — not real secrets).
BOOKER_USERNAME=admin
BOOKER_PASSWORD=password123

# Logging verbosity: error | warn | info | http | debug
LOG_LEVEL=info

# Network behavior toggles
IGNORE_HTTPS_ERRORS=false
API_TIMEOUT_MS=30000
