{
  "name": "omniapi-playwright-framework",
  "version": "1.0.0",
  "description": "OmniAPI — Enterprise API Automation Framework using Playwright + TypeScript",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:foundation": "playwright test tests/foundation",
    "test:crud": "playwright test tests/crud",
    "test:report": "playwright show-report",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,json,md}\"",
    "clean": "rimraf playwright-report test-results allure-results dist",
    "prepare": "husky"
  },
  "keywords": [
    "playwright",
    "typescript",
    "api-testing",
    "automation",
    "enterprise",
    "qa"
  ],
  "author": "OmniAPI",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "winston": "^3.17.0",
    "ws": "^8.21.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
